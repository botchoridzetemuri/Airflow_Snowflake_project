{"timestamp":"2026-03-30T15:57:27.266038Z","level":"info","event":"Running statement: INSERT INTO DWH.FACT_TRAVEL (\n  ROW_ID,\n  PASSENGER_KEY,\n  AIRPORT_KEY,\n  ARRIVAL_AIRPORT_KEY,\n  PILOT_KEY,\n  TICKET_TYPE_KEY,\n  STATUS_KEY,\n  DEPARTURE_DATE_KEY\n)\nSELECT\n  c.ROW_ID,\n  p.PASSENGER_KEY,\n  a.AIRPORT_KEY,\n  aa.ARRIVAL_AIRPORT_KEY,\n  pi.PILOT_KEY,\n  t.TICKET_TYPE_KEY,\n  s.STATUS_KEY,\n  d.DATE_KEY\nFROM CLEAN.TRAVEL_CLEAN c\nJOIN DWH.DIM_PASSENGER p\n  ON p.PASSENGER_ID = c.PASSENGER_ID\nJOIN DWH.DIM_AIRPORT a\n  ON a.AIRPORT_NAME = c.AIRPORT_NAME\n AND a.AIRPORT_COUNTRY_CODE = c.AIRPORT_COUNTRY_CODE\nJOIN DWH.DIM_ARRIVAL_AIRPORT aa\n  ON aa.ARRIVAL_AIRPORT = c.ARRIVAL_AIRPORT\nJOIN DWH.DIM_PILOT pi\n  ON pi.PILOT_NAME = c.PILOT_NAME\nJOIN DWH.DIM_TICKET_TYPE t\n  ON t.TICKET_TYPE = c.TICKET_TYPE\nJOIN DWH.DIM_STATUS s\n  ON s.FLIGHT_STATUS = c.FLIGHT_STATUS\n AND s.PASSENGER_STATUS = c.PASSENGER_STATUS\nLEFT JOIN DWH.DIM_DATE d\n  ON d.FULL_DATE = c.DEPARTURE_DATE;, parameters: None","logger":"airflow.task.hooks.airflow.providers.snowflake.hooks.snowflake.SnowflakeHook","filename":"snowflake.py","lineno":703}
{"timestamp":"2026-03-30T15:57:27.266095Z","level":"info","event":"Running statement: INSERT INTO DWH.FACT_TRAVEL (\n  ROW_ID,\n  PASSENGER_KEY,\n  AIRPORT_KEY,\n  ARRIVAL_AIRPORT_KEY,\n  PILOT_KEY,\n  TICKET_TYPE_KEY,\n  STATUS_KEY,\n  DEPARTURE_DATE_KEY\n)\nSELECT\n  c.ROW_ID,\n  p.PASSENGER_KEY,\n  a.AIRPORT_KEY,\n  aa.ARRIVAL_AIRPORT_KEY,\n  pi.PILOT_KEY,\n  t.TICKET_TYPE_KEY,\n  s.STATUS_KEY,\n  d.DATE_KEY\nFROM CLEAN.TRAVEL_CLEAN c\nJOIN DWH.DIM_PASSENGER p\n  ON p.PASSENGER_ID = c.PASSENGER_ID\nJOIN DWH.DIM_AIRPORT a\n  ON a.AIRPORT_NAME = c.AIRPORT_NAME\n AND a.AIRPORT_COUNTRY_CODE = c.AIRPORT_COUNTRY_CODE\nJOIN DWH.DIM_ARRIVAL_AIRPORT aa\n  ON aa.ARRIVAL_AIRPORT = c.ARRIVAL_AIRPORT\nJOIN DWH.DIM_PILOT pi\n  ON pi.PILOT_NAME = c.PILOT_NAME\nJOIN DWH.DIM_TICKET_TYPE t\n  ON t.TICKET_TYPE = c.TICKET_TYPE\nJOIN DWH.DIM_STATUS s\n  ON s.FLIGHT_STATUS = c.FLIGHT_STATUS\n AND s.PASSENGER_STATUS = c.PASSENGER_STATUS\nLEFT JOIN DWH.DIM_DATE d\n  ON d.FULL_DATE = c.DEPARTURE_DATE;, parameters: None","logger":"airflow.task.hooks.airflow.providers.snowflake.hooks.snowflake.SnowflakeHook","filename":"sql.py","lineno":829}
